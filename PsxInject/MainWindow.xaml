<Window x:Class="PsxInject.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:PsxInject.ViewModels"
        xmlns:m="clr-namespace:PsxInject.Models"
        xmlns:sys="clr-namespace:System;assembly=System.Runtime"
        Title="PSX inject"
        Icon="/Assets/app.ico"
        Width="1100" Height="720"
        MinWidth="900" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource B.Bg}"
        TextOptions.TextFormattingMode="Ideal"
        TextOptions.TextRenderingMode="ClearType"
        UseLayoutRounding="True">

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- ===================== Sidebar ===================== -->
        <Border Grid.Column="0" Background="{StaticResource B.BgElevated}"
                BorderBrush="{StaticResource B.BorderSubtle}" BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Brand -->
                <StackPanel Grid.Row="0" Margin="20,24,20,18">
                    <StackPanel Orientation="Horizontal">
                        <Border Width="32" Height="32" CornerRadius="8"
                                Background="{StaticResource B.AccentGradient}"
                                VerticalAlignment="Center">
                            <TextBlock Text="PS" Foreground="White" FontWeight="Bold"
                                       FontSize="13" HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Border>
                        <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="PSX inject" FontWeight="SemiBold" FontSize="14" />
                            <TextBlock Text="Download proxy" Style="{StaticResource Subtle}" />
                        </StackPanel>
                    </StackPanel>
                </StackPanel>

                <!-- Nav -->
                <StackPanel Grid.Row="1" Margin="0,8,0,0">
                    <RadioButton Style="{StaticResource NavButton}" GroupName="Nav"
                                 Content="◉  Dashboard"
                                 IsChecked="{Binding SelectedTab, Mode=TwoWay,
                                                     Converter={StaticResource IntEqBool}, ConverterParameter=0}" />
                    <RadioButton Style="{StaticResource NavButton}" GroupName="Nav"
                                 Content="≡  Requests"
                                 IsChecked="{Binding SelectedTab, Mode=TwoWay,
                                                     Converter={StaticResource IntEqBool}, ConverterParameter=1}" />
                    <RadioButton Style="{StaticResource NavButton}" GroupName="Nav"
                                 Content="▤  Cached Files"
                                 IsChecked="{Binding SelectedTab, Mode=TwoWay,
                                                     Converter={StaticResource IntEqBool}, ConverterParameter=2}" />
                    <RadioButton Style="{StaticResource NavButton}" GroupName="Nav"
                                 Content="🎮  Games"
                                 IsChecked="{Binding SelectedTab, Mode=TwoWay,
                                                     Converter={StaticResource IntEqBool}, ConverterParameter=3}" />
                    <RadioButton Style="{StaticResource NavButton}" GroupName="Nav"
                                 Content="⚙  Settings"
                                 IsChecked="{Binding SelectedTab, Mode=TwoWay,
                                                     Converter={StaticResource IntEqBool}, ConverterParameter=4}" />
                </StackPanel>

                <!-- Bottom status -->
                <Border Grid.Row="2" Margin="16" Padding="12" CornerRadius="8"
                        Background="{StaticResource B.Surface}"
                        BorderBrush="{StaticResource B.BorderSubtle}" BorderThickness="1">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="9" Height="9" VerticalAlignment="Center">
                                <Ellipse.Style>
                                    <Style TargetType="Ellipse">
                                        <Setter Property="Fill" Value="{StaticResource B.TextMuted}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                                <Setter Property="Fill" Value="{StaticResource B.Success}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Ellipse.Style>
                            </Ellipse>
                            <TextBlock Margin="9,0,0,0" FontWeight="SemiBold">
                                <Run Text="Server: " Foreground="{StaticResource B.TextDim}" />
                                <Run>
                                    <Run.Style>
                                        <Style TargetType="Run">
                                            <Setter Property="Text" Value="STOPPED" />
                                            <Setter Property="Foreground" Value="{StaticResource B.TextDim}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                                    <Setter Property="Text" Value="RUNNING" />
                                                    <Setter Property="Foreground" Value="{StaticResource B.Success}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Run.Style>
                                </Run>
                            </TextBlock>
                        </StackPanel>
                        <TextBlock Style="{StaticResource Subtle}" Margin="0,6,0,0"
                                   Text="{Binding StatusText}" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- ===================== Content ===================== -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Top toolbar -->
            <Grid Grid.Row="0" Margin="32,24,32,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock x:Name="PageTitle" Style="{StaticResource H1}" Text="Dashboard" />
                    <TextBlock x:Name="PageSub" Style="{StaticResource Subtle}"
                               Text="Live proxy and cache status." Margin="0,2,0,0" />
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Style="{StaticResource BtnPrimary}" Content="▶  Start"
                            Command="{Binding StartCommand}"
                            Visibility="{Binding IsRunning, Converter={StaticResource BoolToVis}, ConverterParameter=invert}" />
                    <Button Style="{StaticResource BtnDanger}" Content="■  Stop"
                            Command="{Binding StopCommand}"
                            Visibility="{Binding IsRunning, Converter={StaticResource BoolToVis}}" />
                    <Button Style="{StaticResource BtnGhost}" Content="↻  Restart" Margin="8,0,0,0"
                            Command="{Binding RestartCommand}"
                            IsEnabled="{Binding IsRunning}" />
                </StackPanel>
            </Grid>

            <!-- Banners (port conflict, firewall) -->
            <StackPanel Grid.Row="1" Margin="32,4,32,4">
                <Border Background="#33FBBF24" BorderBrush="{StaticResource B.Warning}"
                        BorderThickness="1" CornerRadius="8" Padding="14,12" Margin="0,0,0,8"
                        Visibility="{Binding IsPortConflictBannerVisible, Converter={StaticResource BoolToVis}}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock FontWeight="SemiBold" Foreground="{StaticResource B.Warning}">
                                <Run Text="Port" />
                                <Run Text="{Binding ConflictingPort, Mode=OneWay}" />
                                <Run Text="is already in use." />
                            </TextBlock>
                            <TextBlock Style="{StaticResource Subtle}" Margin="0,2,0,0" TextWrapping="Wrap">
                                <Run Text="Port" />
                                <Run Text="{Binding SuggestedPort, Mode=OneWay}" />
                                <Run Text="is free — click below to use it (saved automatically)." />
                            </TextBlock>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <Button Style="{StaticResource BtnPrimary}"
                                    Command="{Binding UseSuggestedPortCommand}">
                                <TextBlock>
                                    <Run Text="Use port" />
                                    <Run Text="{Binding SuggestedPort, Mode=OneWay}" />
                                </TextBlock>
                            </Button>
                            <Button Style="{StaticResource BtnGhost}" Content="Open Settings" Margin="8,0,0,0"
                                    Command="{Binding OpenSettingsFromBannerCommand}" />
                            <Button Style="{StaticResource BtnSmall}" Content="✕" Margin="8,0,0,0"
                                    Command="{Binding DismissPortConflictCommand}" />
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Background="#330070D1" BorderBrush="{StaticResource B.AccentBright}"
                        BorderThickness="1" CornerRadius="8" Padding="14,12"
                        Visibility="{Binding IsFirewallBannerVisible, Converter={StaticResource BoolToVis}}">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock FontWeight="SemiBold" Foreground="{StaticResource B.AccentBright}"
                                           Text="Allow LAN access through Windows Firewall" />
                                <TextBlock Style="{StaticResource Subtle}" Margin="0,2,0,0" TextWrapping="Wrap"
                                           Text="{Binding FirewallBannerText}" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                <Button Style="{StaticResource BtnPrimary}" Content="🛡  Allow LAN access"
                                        Command="{Binding AllowFirewallCommand}"
                                        IsEnabled="{Binding IsFirewallBusy, Converter={StaticResource InvBool}}" />
                                <Button Style="{StaticResource BtnSmall}" Content="✕" Margin="8,0,0,0"
                                        Command="{Binding DismissFirewallCommand}" />
                            </StackPanel>
                        </Grid>

                        <!-- Error detail when add fails -->
                        <Border Margin="0,12,0,0" Padding="12" CornerRadius="6"
                                Background="{StaticResource B.Surface}"
                                BorderBrush="{StaticResource B.Border}" BorderThickness="1"
                                Visibility="{Binding IsFirewallErrorVisible, Converter={StaticResource BoolToVis}}">
                            <StackPanel>
                                <TextBlock FontWeight="SemiBold" Foreground="{StaticResource B.Error}"
                                           Text="The automatic add did not succeed." />
                                <TextBox Margin="0,8,0,0"
                                         IsReadOnly="True"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         MaxHeight="220"
                                         VerticalScrollBarVisibility="Auto"
                                         FontFamily="Consolas, Cascadia Mono, Courier New"
                                         FontSize="12"
                                         Text="{Binding FirewallErrorDetail, Mode=OneWay}" />

                                <TextBlock Margin="0,12,0,0" Foreground="{StaticResource B.TextDim}"
                                           TextWrapping="Wrap"
                                           Text="As a fallback, copy the command below and paste it into an Administrator Command Prompt:" />
                                <Grid Margin="0,6,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox Grid.Column="0" IsReadOnly="True"
                                             FontFamily="Consolas, Cascadia Mono, Courier New" FontSize="12"
                                             Text="{Binding FirewallManualCommand, Mode=OneWay}" />
                                    <Button Grid.Column="1" Style="{StaticResource BtnGhost}" Content="📋  Copy"
                                            Margin="8,0,0,0"
                                            Command="{Binding CopyFirewallCommandCommand}" />
                                    <Button Grid.Column="2" Style="{StaticResource BtnGhost}" Content="↻  Try again"
                                            Margin="8,0,0,0"
                                            Command="{Binding AllowFirewallCommand}"
                                            IsEnabled="{Binding IsFirewallBusy, Converter={StaticResource InvBool}}" />
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- Pages: switch via SelectedTab -->
            <Grid Grid.Row="2" Margin="32,8,32,24">

                <!-- ============= Dashboard ============= -->
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                              Visibility="{Binding SelectedTab, Converter={StaticResource IntEqVis}, ConverterParameter=0}">
                    <StackPanel x:Name="DashboardPanel">
                        <!-- Hero -->
                        <Border Background="{StaticResource B.HeroGradient}" CornerRadius="12" Padding="28"
                                BorderBrush="{StaticResource B.Border}" BorderThickness="1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="PROXY ENDPOINT" Style="{StaticResource Subtle}"
                                               FontWeight="SemiBold" Foreground="{StaticResource B.AccentBright}" />
                                    <TextBlock Style="{StaticResource H1}" Margin="0,4,0,0"
                                               Text="{Binding ProxyHint}" />
                                    <TextBlock Style="{StaticResource Subtle}" Margin="0,8,0,0" TextWrapping="Wrap"
                                               Text="On your PS4: Network Settings → Set up Internet → Manual proxy.  Use this address and port. Pause and resume your download to route it through this proxy." />

                                    <ItemsControl Margin="0,14,0,0" ItemsSource="{Binding LocalAddresses}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="{StaticResource B.Surface}"
                                                        BorderBrush="{StaticResource B.Border}" BorderThickness="1"
                                                        CornerRadius="6" Padding="10,4" Margin="0,0,8,8">
                                                    <TextBlock Style="{StaticResource Mono}" Text="{Binding}" />
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>

                                <StackPanel Grid.Column="1" VerticalAlignment="Top">
                                    <Button Style="{StaticResource BtnGhost}" Content="↻  Refresh IPs"
                                            Command="{Binding RefreshLocalAddressesCommand}" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Sony servers toggle -->
                        <Border Style="{StaticResource Card}" Margin="0,12,0,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Style="{StaticResource H2}" Text="Sony servers" />
                                    <TextBlock Style="{StaticResource Subtle}" Margin="0,4,0,0" TextWrapping="Wrap">
                                        <Run Text="When PS4 requests a .pkg file that isn't in your cache:" />
                                    </TextBlock>
                                    <TextBlock Margin="0,6,0,0"
                                               Foreground="{StaticResource B.Warning}"
                                               Visibility="{Binding AllowSonyFallback, Converter={StaticResource BoolToVis}, ConverterParameter=invert}"
                                               TextWrapping="Wrap"
                                               Text="🚫  BLOCKED — request returns 404. Place files in the data folder manually." />
                                    <TextBlock Margin="0,6,0,0"
                                               Foreground="{StaticResource B.AccentBright}"
                                               Visibility="{Binding AllowSonyFallback, Converter={StaticResource BoolToVis}}"
                                               TextWrapping="Wrap"
                                               Text="✓  ALLOWED — PS4 downloads through this proxy directly from PSN." />
                                </StackPanel>

                                <Border Grid.Column="1" Background="{StaticResource B.Surface}"
                                        BorderBrush="{StaticResource B.Border}" BorderThickness="1"
                                        CornerRadius="8" Padding="3" VerticalAlignment="Center"
                                        Margin="20,0,0,0">
                                    <StackPanel Orientation="Horizontal">
                                        <RadioButton Style="{StaticResource SegmentedRadio}" GroupName="SonyMode"
                                                     Content="🚫  Block"
                                                     IsChecked="{Binding AllowSonyFallback, Converter={StaticResource InvBool}, Mode=OneWay}" />
                                        <RadioButton Style="{StaticResource SegmentedRadio}" GroupName="SonyMode"
                                                     Content="✓  Allow"
                                                     IsChecked="{Binding AllowSonyFallback, Mode=TwoWay}" />
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Border>

                        <!-- Stat row -->
                        <UniformGrid Columns="4" Margin="0,16,0,0">
                            <Border Style="{StaticResource StatCard}" Margin="0,0,8,0">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource Subtle}" Text="TOTAL REQUESTS" />
                                    <TextBlock Style="{StaticResource H1}" Text="{Binding TotalRequests}" Margin="0,4,0,0" />
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource StatCard}" Margin="4,0">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource Subtle}" Text="CACHE HITS" Foreground="{StaticResource B.Success}" />
                                    <TextBlock Style="{StaticResource H1}" Text="{Binding CacheHits}" Margin="0,4,0,0" />
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource StatCard}" Margin="4,0">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource Subtle}" Text="CACHE MISSES" Foreground="{StaticResource B.Warning}" />
                                    <TextBlock Style="{StaticResource H1}" Text="{Binding CacheMisses}" Margin="0,4,0,0" />
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource StatCard}" Margin="8,0,0,0">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource Subtle}" Text="ERRORS" Foreground="{StaticResource B.Error}" />
                                    <TextBlock Style="{StaticResource H1}" Text="{Binding Errors}" Margin="0,4,0,0" />
                                </StackPanel>
                            </Border>
                        </UniformGrid>

                        <UniformGrid Columns="3" Margin="0,12,0,0">
                            <Border Style="{StaticResource StatCard}" Margin="0,0,8,0">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource Subtle}" Text="PROXY REQUESTS" />
                                    <TextBlock Style="{StaticResource H2}" Text="{Binding ProxyRequests}" Margin="0,4,0,0" />
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource StatCard}" Margin="4,0">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource Subtle}" Text="BYTES SERVED" />
                                    <TextBlock Style="{StaticResource H2}" Text="{Binding BytesServedText}" Margin="0,4,0,0" />
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource StatCard}" Margin="8,0,0,0">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource Subtle}" Text="UPTIME" />
                                    <TextBlock Style="{StaticResource H2}" Text="{Binding UptimeText}" Margin="0,4,0,0" />
                                </StackPanel>
                            </Border>
                        </UniformGrid>

                        <!-- Cache summary -->
                        <Border Style="{StaticResource Card}" Margin="0,16,0,16">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Style="{StaticResource H2}" Text="Cache" />
                                    <TextBlock Style="{StaticResource Subtle}" Margin="0,4,0,0">
                                        <Run Text="{Binding CachedFileCount, Mode=OneWay}" />
                                        <Run Text="files •" />
                                        <Run Text="{Binding CachedTotalText, Mode=OneWay}" />
                                    </TextBlock>
                                    <TextBlock Style="{StaticResource Mono}" Margin="0,6,0,0"
                                               Foreground="{StaticResource B.TextDim}"
                                               Text="{Binding DataDirectory}" TextWrapping="Wrap" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                    <Button Style="{StaticResource BtnGhost}" Content="Open Folder"
                                            Command="{Binding OpenDataFolderCommand}" />
                                    <Button Style="{StaticResource BtnGhost}" Content="Refresh" Margin="8,0,0,0"
                                            Command="{Binding RefreshCachedFilesCommand}" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <!-- ============= Requests ============= -->
                <Grid Visibility="{Binding SelectedTab, Converter={StaticResource IntEqVis}, ConverterParameter=1}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Style="{StaticResource Subtle}" VerticalAlignment="Center"
                                   Text="Newest first.  Cache misses show a 'Copy URL' button — paste it into your download manager." />
                        <Button Grid.Column="1" Style="{StaticResource BtnGhost}" Content="Clear"
                                Command="{Binding ClearLogCommand}" />
                    </Grid>

                    <Border Grid.Row="1" Style="{StaticResource Card}" Padding="0">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                            <ItemsControl ItemsSource="{Binding Requests}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type m:RequestLogEntry}">
                                        <Grid Margin="16,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="60" />
                                                <ColumnDefinition Width="70" />
                                                <ColumnDefinition Width="50" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Grid.Column="0" Style="{StaticResource Mono}"
                                                       Foreground="{StaticResource B.TextDim}"
                                                       Text="{Binding TimeText}" VerticalAlignment="Center" />

                                            <Border Grid.Column="1" Style="{StaticResource KindPill}"
                                                    Background="{Binding Kind, Converter={StaticResource KindBrush}}"
                                                    Margin="0,0,8,0">
                                                <TextBlock Text="{Binding KindText}" FontSize="11" FontWeight="Bold"
                                                           Foreground="#FF0A0E1A" HorizontalAlignment="Center" />
                                            </Border>

                                            <TextBlock Grid.Column="2" Style="{StaticResource Mono}"
                                                       Text="{Binding Method}" VerticalAlignment="Center"
                                                       Foreground="{StaticResource B.TextDim}" />

                                            <StackPanel Grid.Column="3" VerticalAlignment="Center" Margin="4,0,8,0">
                                                <TextBlock TextTrimming="CharacterEllipsis"
                                                           Text="{Binding FileName}"
                                                           Visibility="{Binding FileName, Converter={StaticResource NullToColl}}" />
                                                <TextBlock Style="{StaticResource Mono}"
                                                           Foreground="{StaticResource B.TextDim}"
                                                           TextTrimming="CharacterEllipsis"
                                                           Text="{Binding Url}" />
                                                <TextBlock Style="{StaticResource Subtle}"
                                                           Text="{Binding Detail}"
                                                           Visibility="{Binding Detail, Converter={StaticResource NullToColl}}" />
                                            </StackPanel>

                                            <TextBlock Grid.Column="4" Style="{StaticResource Mono}"
                                                       Foreground="{StaticResource B.TextDim}"
                                                       VerticalAlignment="Center" Margin="0,0,12,0"
                                                       Text="{Binding Bytes, Converter={StaticResource BytesFmt}}" />

                                            <Button Grid.Column="5" Style="{StaticResource BtnSmall}"
                                                    Content="📋  Copy URL"
                                                    Visibility="{Binding IsCopyable, Converter={StaticResource BoolToVis}}"
                                                    Command="{Binding DataContext.CopyTextCommand,
                                                              RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding Url}" />
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Border>
                </Grid>

                <!-- ============= Cached Files ============= -->
                <Grid Visibility="{Binding SelectedTab, Converter={StaticResource IntEqVis}, ConverterParameter=2}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Style="{StaticResource Subtle}">
                                <Run Text="{Binding CachedFileCount, Mode=OneWay}" />
                                <Run Text="files in cache •" />
                                <Run Text="{Binding CachedTotalText, Mode=OneWay}" />
                            </TextBlock>
                            <TextBlock Style="{StaticResource Mono}" Margin="0,4,0,0"
                                       Foreground="{StaticResource B.TextDim}"
                                       Text="{Binding DataDirectory}" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Button Style="{StaticResource BtnGhost}" Content="Open Folder"
                                    Command="{Binding OpenDataFolderCommand}" />
                            <Button Style="{StaticResource BtnGhost}" Content="↻  Refresh" Margin="8,0,0,0"
                                    Command="{Binding RefreshCachedFilesCommand}" />
                        </StackPanel>
                    </Grid>

                    <Border Grid.Row="1" Style="{StaticResource Card}" Padding="0">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                            <ItemsControl ItemsSource="{Binding CachedFiles}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type m:CachedFile}">
                                        <Grid Margin="20,10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="120" />
                                                <ColumnDefinition Width="160" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Name}" TextTrimming="CharacterEllipsis" />
                                                <TextBlock Style="{StaticResource Subtle}" Margin="0,2,0,0"
                                                           Text="{Binding FullPath}" TextTrimming="CharacterEllipsis" />
                                            </StackPanel>
                                            <TextBlock Grid.Column="1" Style="{StaticResource Mono}"
                                                       VerticalAlignment="Center" Text="{Binding SizeText}"
                                                       Foreground="{StaticResource B.TextDim}" />
                                            <TextBlock Grid.Column="2" Style="{StaticResource Mono}"
                                                       VerticalAlignment="Center" Text="{Binding ModifiedText}"
                                                       Foreground="{StaticResource B.TextDim}" />
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Border>
                </Grid>

                <!-- ============= Games ============= -->
                <Grid Visibility="{Binding SelectedTab, Converter={StaticResource IntEqVis}, ConverterParameter=3}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Style="{StaticResource Subtle}" TextWrapping="Wrap"
                                       Text="Games are detected from cached file names by Title ID. Each card lists base game files and updates separately. You can rename a game and your label is saved." />
                        </StackPanel>
                        <Button Grid.Column="1" Style="{StaticResource BtnGhost}" Content="↻  Refresh"
                                Command="{Binding RefreshCachedFilesCommand}" />
                    </Grid>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <Grid>
                            <!-- Empty state -->
                            <Border Style="{StaticResource Card}" Padding="32"
                                    Visibility="{Binding Games.Count, Converter={StaticResource IntEqVis}, ConverterParameter=0}">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Style="{StaticResource H2}" Text="No games detected yet."
                                               HorizontalAlignment="Center" />
                                    <TextBlock Style="{StaticResource Subtle}" Margin="0,6,0,0"
                                               TextAlignment="Center" TextWrapping="Wrap" MaxWidth="500"
                                               Text="Once you place .pkg files in your data folder (or enable Sony fallback), they'll be grouped here by Title ID." />
                                </StackPanel>
                            </Border>

                            <ItemsControl ItemsSource="{Binding Games}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type m:Game}">
                                        <Border Style="{StaticResource Card}" Margin="0,0,0,12" Padding="0"
                                                ClipToBounds="True">
                                            <Grid>
                                                <!-- Faded background image -->
                                                <Image Stretch="UniformToFill" Opacity="0.18"
                                                       VerticalAlignment="Top" HorizontalAlignment="Stretch"
                                                       Source="{Binding BackgroundUrl, IsAsync=True}"
                                                       Visibility="{Binding HasBackground, Converter={StaticResource BoolToVis}}" />
                                                <Border Background="{StaticResource B.HeroGradient}" Opacity="0.85" />

                                                <StackPanel Margin="20">
                                                    <!-- Header row -->
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>

                                                        <!-- Icon -->
                                                        <Border Grid.Column="0" Width="76" Height="76"
                                                                CornerRadius="10" Margin="0,0,16,0"
                                                                BorderBrush="{StaticResource B.Border}" BorderThickness="1"
                                                                Background="{StaticResource B.Surface}"
                                                                ClipToBounds="True">
                                                            <Grid>
                                                                <TextBlock Text="🎮" FontSize="34"
                                                                           Foreground="{StaticResource B.TextDim}"
                                                                           HorizontalAlignment="Center"
                                                                           VerticalAlignment="Center" />
                                                                <Image Stretch="UniformToFill"
                                                                       Source="{Binding IconUrl, IsAsync=True}"
                                                                       Visibility="{Binding HasIcon, Converter={StaticResource BoolToVis}}" />
                                                            </Grid>
                                                        </Border>

                                                        <!-- Name + meta -->
                                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                            <TextBlock Style="{StaticResource H1}" FontSize="22"
                                                                       Text="{Binding EffectiveName}"
                                                                       TextTrimming="CharacterEllipsis" />
                                                            <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                                                <Border Background="{StaticResource B.AccentDim}"
                                                                        CornerRadius="4" Padding="6,1">
                                                                    <TextBlock Text="{Binding TitleId}"
                                                                               Style="{StaticResource Mono}"
                                                                               FontSize="11"
                                                                               Foreground="{StaticResource B.AccentBright}" />
                                                                </Border>
                                                                <Border Background="{StaticResource B.Surface}"
                                                                        CornerRadius="4" Padding="6,1" Margin="6,0,0,0"
                                                                        Visibility="{Binding HasCategory, Converter={StaticResource BoolToVis}}">
                                                                    <TextBlock Text="{Binding CategoryText}"
                                                                               FontSize="11"
                                                                               Foreground="{StaticResource B.TextDim}" />
                                                                </Border>
                                                                <TextBlock Style="{StaticResource Subtle}" Margin="10,0,0,0"
                                                                           VerticalAlignment="Center">
                                                                    <Run Text="{Binding FileCount, Mode=OneWay}" />
                                                                    <Run Text="files •" />
                                                                    <Run Text="{Binding TotalSizeText, Mode=OneWay}" />
                                                                </TextBlock>
                                                            </StackPanel>
                                                            <TextBlock Style="{StaticResource Mono}" FontSize="11"
                                                                       Foreground="{StaticResource B.TextMuted}"
                                                                       Margin="0,6,0,0"
                                                                       TextTrimming="CharacterEllipsis"
                                                                       Text="{Binding ContentId}"
                                                                       Visibility="{Binding HasContentId, Converter={StaticResource BoolToVis}}" />
                                                        </StackPanel>

                                                        <!-- Actions -->
                                                        <StackPanel Grid.Column="2" Orientation="Vertical" VerticalAlignment="Top"
                                                                    HorizontalAlignment="Right">
                                                            <Button Style="{StaticResource BtnPrimary}"
                                                                    Content="📋  Copy all links"
                                                                    HorizontalAlignment="Right"
                                                                    Padding="14,8" FontSize="12"
                                                                    Command="{Binding DataContext.CopyAllLinksCommand,
                                                                              RelativeSource={RelativeSource AncestorType=Window}}"
                                                                    CommandParameter="{Binding}" />
                                                            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                                                <TextBox Width="140" FontSize="11"
                                                                         Padding="8,4"
                                                                         Background="{StaticResource B.Surface}"
                                                                         ToolTip="Override the display name"
                                                                         Text="{Binding DisplayName, UpdateSourceTrigger=PropertyChanged}" />
                                                                <Button Style="{StaticResource BtnSmall}" Margin="6,0,0,0"
                                                                        Content="Save"
                                                                        Command="{Binding DataContext.RenameGameCommand,
                                                                                  RelativeSource={RelativeSource AncestorType=Window}}"
                                                                        CommandParameter="{Binding}" />
                                                            </StackPanel>
                                                        </StackPanel>
                                                    </Grid>

                                                    <Border Style="{StaticResource Divider}" Margin="0,14,0,14" />

                                                <!-- Game files -->
                                                <StackPanel Visibility="{Binding HasGameFiles, Converter={StaticResource BoolToVis}}">
                                                    <TextBlock FontWeight="SemiBold" Foreground="{StaticResource B.AccentBright}"
                                                               Text="GAME FILES" FontSize="11" />
                                                    <ItemsControl ItemsSource="{Binding GameFiles}" Margin="0,6,0,0">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate DataType="{x:Type m:CachedFile}">
                                                                <Grid Margin="0,4">
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="*" />
                                                                        <ColumnDefinition Width="80" />
                                                                        <ColumnDefinition Width="120" />
                                                                        <ColumnDefinition Width="Auto" />
                                                                    </Grid.ColumnDefinitions>
                                                                    <TextBlock Grid.Column="0"
                                                                               TextTrimming="CharacterEllipsis"
                                                                               VerticalAlignment="Center">
                                                                        <TextBlock.Style>
                                                                            <Style TargetType="TextBlock">
                                                                                <Setter Property="Text" Value="{Binding Name}" />
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding IsCached}" Value="False">
                                                                                        <Setter Property="FontStyle" Value="Italic" />
                                                                                        <Setter Property="Foreground" Value="{StaticResource B.TextDim}" />
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </TextBlock.Style>
                                                                    </TextBlock>
                                                                    <TextBlock Grid.Column="1" Style="{StaticResource Mono}"
                                                                               Foreground="{StaticResource B.TextDim}"
                                                                               VerticalAlignment="Center"
                                                                               Text="{Binding SizeText}" />
                                                                    <TextBlock Grid.Column="2" Style="{StaticResource Mono}"
                                                                               Foreground="{StaticResource B.TextDim}"
                                                                               VerticalAlignment="Center"
                                                                               Text="{Binding ModifiedText}" />
                                                                    <Button Grid.Column="3" Style="{StaticResource BtnSmall}"
                                                                            Content="📋  Copy URL" Margin="8,0,0,0"
                                                                            Visibility="{Binding HasSourceUrl, Converter={StaticResource BoolToVis}}"
                                                                            Command="{Binding DataContext.CopyTextCommand,
                                                                                      RelativeSource={RelativeSource AncestorType=Window}}"
                                                                            CommandParameter="{Binding SourceUrl}" />
                                                                </Grid>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </StackPanel>

                                                <!-- Updates -->
                                                <StackPanel Margin="0,14,0,0"
                                                            Visibility="{Binding HasUpdates, Converter={StaticResource BoolToVis}}">
                                                    <TextBlock FontWeight="SemiBold" Foreground="{StaticResource B.Warning}"
                                                               Text="UPDATES" FontSize="11" />
                                                    <ItemsControl ItemsSource="{Binding Updates}" Margin="0,6,0,0">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate DataType="{x:Type m:CachedFile}">
                                                                <Grid Margin="0,4">
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="*" />
                                                                        <ColumnDefinition Width="80" />
                                                                        <ColumnDefinition Width="120" />
                                                                        <ColumnDefinition Width="Auto" />
                                                                    </Grid.ColumnDefinitions>
                                                                    <TextBlock Grid.Column="0"
                                                                               TextTrimming="CharacterEllipsis"
                                                                               VerticalAlignment="Center">
                                                                        <TextBlock.Style>
                                                                            <Style TargetType="TextBlock">
                                                                                <Setter Property="Text" Value="{Binding Name}" />
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding IsCached}" Value="False">
                                                                                        <Setter Property="FontStyle" Value="Italic" />
                                                                                        <Setter Property="Foreground" Value="{StaticResource B.TextDim}" />
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </TextBlock.Style>
                                                                    </TextBlock>
                                                                    <TextBlock Grid.Column="1" Style="{StaticResource Mono}"
                                                                               Foreground="{StaticResource B.TextDim}"
                                                                               VerticalAlignment="Center"
                                                                               Text="{Binding SizeText}" />
                                                                    <TextBlock Grid.Column="2" Style="{StaticResource Mono}"
                                                                               Foreground="{StaticResource B.TextDim}"
                                                                               VerticalAlignment="Center"
                                                                               Text="{Binding ModifiedText}" />
                                                                    <Button Grid.Column="3" Style="{StaticResource BtnSmall}"
                                                                            Content="📋  Copy URL" Margin="8,0,0,0"
                                                                            Visibility="{Binding HasSourceUrl, Converter={StaticResource BoolToVis}}"
                                                                            Command="{Binding DataContext.CopyTextCommand,
                                                                                      RelativeSource={RelativeSource AncestorType=Window}}"
                                                                            CommandParameter="{Binding SourceUrl}" />
                                                                </Grid>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </StackPanel>
                                            </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>
                    </ScrollViewer>
                </Grid>

                <!-- ============= Settings ============= -->
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                              Visibility="{Binding SelectedTab, Converter={StaticResource IntEqVis}, ConverterParameter=4}">
                    <StackPanel MaxWidth="640" HorizontalAlignment="Left">
                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Style="{StaticResource H2}" Text="Server" />
                                <TextBlock Style="{StaticResource Subtle}" Margin="0,2,0,16"
                                           Text="The proxy listens on all network interfaces. Make sure Windows Firewall allows it on your Private network." />

                                <TextBlock Text="Port" Margin="0,0,0,4" Foreground="{StaticResource B.TextDim}" />
                                <TextBox Text="{Binding Port, UpdateSourceTrigger=PropertyChanged}"
                                         MaxWidth="160" HorizontalAlignment="Left" />

                                <TextBlock Text="Data folder" Margin="0,16,0,4" Foreground="{StaticResource B.TextDim}" />
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox Grid.Column="0"
                                             Text="{Binding DataDirectory, UpdateSourceTrigger=PropertyChanged}" />
                                    <Button Grid.Column="1" Style="{StaticResource BtnGhost}" Content="Browse…"
                                            Margin="8,0,0,0" Command="{Binding BrowseDataFolderCommand}" />
                                    <Button Grid.Column="2" Style="{StaticResource BtnGhost}" Content="Reset"
                                            Margin="8,0,0,0" Command="{Binding ResetDataFolderCommand}" />
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource Card}" Margin="0,16,0,0">
                            <StackPanel>
                                <TextBlock Style="{StaticResource H2}" Text="Behavior" />
                                <CheckBox Margin="0,12,0,0"
                                          IsChecked="{Binding AutoStartServer}"
                                          Content="Auto-start the server when the app launches" />

                                <TextBlock Style="{StaticResource Subtle}" Margin="0,16,0,6"
                                           Text="When you close the window:" />
                                <RadioButton GroupName="CloseAction"
                                             Content="Ask me each time"
                                             IsChecked="{Binding CloseAction, Mode=TwoWay,
                                                                 Converter={StaticResource IntEqBool}, ConverterParameter=0}" />
                                <RadioButton GroupName="CloseAction" Margin="0,4,0,0"
                                             Content="Keep running in background (system tray)"
                                             IsChecked="{Binding CloseAction, Mode=TwoWay,
                                                                 Converter={StaticResource IntEqBool}, ConverterParameter=1}" />
                                <RadioButton GroupName="CloseAction" Margin="0,4,0,0"
                                             Content="Stop the server and exit"
                                             IsChecked="{Binding CloseAction, Mode=TwoWay,
                                                                 Converter={StaticResource IntEqBool}, ConverterParameter=2}" />
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource Card}" Margin="0,16,0,0">
                            <StackPanel>
                                <TextBlock Style="{StaticResource H2}" Text="Windows Firewall" />
                                <TextBlock Style="{StaticResource Subtle}" Margin="0,2,0,10" TextWrapping="Wrap"
                                           Text="Adds an inbound allow rule for this exe so your PS4 can reach the proxy. Triggers a UAC prompt." />
                                <Button Style="{StaticResource BtnGhost}" Content="Add / Refresh firewall rule"
                                        HorizontalAlignment="Left"
                                        Command="{Binding AllowFirewallCommand}"
                                        IsEnabled="{Binding IsFirewallBusy, Converter={StaticResource InvBool}}" />
                            </StackPanel>
                        </Border>

                        <StackPanel Orientation="Horizontal" Margin="0,16,0,16">
                            <Button Style="{StaticResource BtnPrimary}" Content="Save"
                                    Command="{Binding SaveSettingsCommand}" />
                            <TextBlock Margin="14,0,0,0" VerticalAlignment="Center"
                                       Style="{StaticResource Subtle}"
                                       Text="Saved to %AppData%\PsxInject\settings.json" />
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>

            </Grid>
        </Grid>
    </Grid>
</Window>
